<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/burger_primary"
            android:paddingHorizontal="20dp"
            android:paddingVertical="18dp"
            android:text="@string/app_name"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/ivBannerLogo"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:adjustViewBounds="true"
            android:background="#F7A523"
            android:contentDescription="@null"
            android:importantForAccessibility="no"
            android:scaleType="fitCenter"
            android:src="@drawable/burger_banner"
            tools:ignore="ImageContrastCheck" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:maxWidth="360dp"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="24dp">

            <TextView
                style="@style/EstiloTexto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/order_title"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/order_subtitle"
                android:textColor="@color/text_secondary"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/etClientName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:autofillHints="name"
                android:backgroundTint="@color/burger_primary"
                android:ems="10"
                android:hint="@string/hint_client_name"
                android:inputType="textPersonName"
                android:maxWidth="360dp"
                android:minHeight="48dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="@string/extras_title"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <CheckBox
                android:id="@+id/cbBacon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:buttonTint="@color/burger_primary"
                android:minHeight="48dp"
                android:paddingVertical="8dp"
                android:text="@string/extra_bacon"
                android:textColor="@color/text_primary" />

            <CheckBox
                android:id="@+id/cbCheese"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="@color/burger_primary"
                android:minHeight="48dp"
                android:paddingVertical="8dp"
                android:text="@string/extra_cheese"
                android:textColor="@color/text_primary" />

            <CheckBox
                android:id="@+id/cbOnionRings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="@color/burger_primary"
                android:minHeight="48dp"
                android:paddingVertical="8dp"
                android:text="@string/extra_onion_rings"
                android:textColor="@color/text_primary" />

            <TextView
                style="@style/EstiloTexto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/quantity_title"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnDecrease"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:backgroundTint="@color/burger_primary"
                    android:text="@string/minus_sign"
                    android:textColor="@color/white"
                    android:textSize="24sp" />

                <TextView
                    android:id="@+id/tvQuantity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="20dp"
                    android:text="@string/default_quantity"
                    android:textColor="@color/text_primary"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnIncrease"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:backgroundTint="@color/burger_primary"
                    android:text="@string/plus_sign"
                    android:textColor="@color/white"
                    android:textSize="20sp" />
            </LinearLayout>

            <TextView
                style="@style/EstiloTexto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="@string/order_summary_title"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:minHeight="24dp"
                android:textColor="@color/text_secondary"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvTotalPrice"
                style="@style/EstiloTexto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/default_total_price"
                android:textColor="@color/burger_primary"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnPlaceOrder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:backgroundTint="@color/burger_primary"
                android:maxWidth="360dp"
                android:paddingVertical="14dp"
                android:text="@string/place_order_button"
                android:textAllCaps="true"
                android:textColor="@color/white"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
